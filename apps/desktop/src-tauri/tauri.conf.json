{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Vigil",
  "version": "0.1.0",
  "identifier": "dev.vigil.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build",
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vigil",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/vigil-sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3NUI2RTQ3RTVERjhDMkEKUldRcWpOL2xSMjViVnlPMjNqVm81L3FmZk5RZXhoMDFDOXVxeUdScTlCUUdJaUc0TUtjVFFvSEYK",
      "endpoints": [
        "https://updates.romans.dev/api/v1/updates/vigil/{{target}}/{{arch}}/v{{current_version}}"
      ]
    }
  }
}
