{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Vigil",
  "version": "0.0.1",
  "identifier": "dev.vigil.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build",
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vigil",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Vigil — Network Watch"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/vigil-sidecar"]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://updates.romans.dev/updates/vigil/{{target}}/{{arch}}/v{{current_version}}"
      ]
    }
  }
}
