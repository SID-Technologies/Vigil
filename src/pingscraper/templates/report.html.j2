<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Wi-Fi Performance Report</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --bg: #0f172a;
    --card: #1e293b;
    --text: #f1f5f9;
    --muted: #94a3b8;
    --good: #10b981;
    --bad: #ef4444;
    --warn: #f59e0b;
    --accent: #3b82f6;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 32px 24px;
    line-height: 1.5;
  }
  .container { max-width: 1200px; margin: 0 auto; }
  h1 { margin: 0 0 4px 0; font-size: 28px; font-weight: 700; }
  .subtitle { color: var(--muted); margin-bottom: 32px; font-size: 14px; }
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }
  .kpi {
    background: var(--card);
    padding: 20px;
    border-radius: 12px;
    border-left: 4px solid var(--accent);
  }
  .kpi.bad { border-left-color: var(--bad); }
  .kpi.warn { border-left-color: var(--warn); }
  .kpi.good { border-left-color: var(--good); }
  .kpi-label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .kpi-value { font-size: 32px; font-weight: 700; margin: 8px 0 4px 0; font-variant-numeric: tabular-nums; }
  .kpi-sub { color: var(--muted); font-size: 13px; }
  .card {
    background: var(--card);
    padding: 24px;
    border-radius: 12px;
    margin-bottom: 24px;
  }
  .card h2 { margin: 0 0 4px 0; font-size: 18px; }
  .card .card-sub { color: var(--muted); font-size: 13px; margin-bottom: 20px; }
  .chart-container { position: relative; height: 320px; }
  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #334155; font-size: 14px; }
  th { color: var(--muted); font-weight: 500; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  tr:last-child td { border-bottom: none; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .footer { color: var(--muted); font-size: 12px; text-align: center; margin-top: 32px; }
  .verdict {
    padding: 16px 20px;
    border-radius: 8px;
    margin-bottom: 24px;
    font-size: 15px;
  }
  .verdict.bad { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); }
  .verdict.good { background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); }
  .verdict-title { font-weight: 700; margin-bottom: 4px; }
  .target-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 16px;
  }
  .target-card {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .target-card.good { border-color: rgba(16, 185, 129, 0.5); }
  .target-card.warn { border-color: rgba(245, 158, 11, 0.5); }
  .target-card.bad { border-color: rgba(239, 68, 68, 0.6); }
  .target-head { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  .target-name { font-weight: 600; font-size: 15px; word-break: break-word; }
  .target-host {
    color: var(--muted); font-size: 12px;
    font-family: "SF Mono", Menlo, Consolas, monospace;
    word-break: break-all;
  }
  .kind-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .kind-badge.icmp { background: rgba(148, 163, 184, 0.2); color: #cbd5e1; }
  .kind-badge.tcp { background: rgba(59, 130, 246, 0.2); color: #93c5fd; }
  .kind-badge.udp_dns { background: rgba(168, 85, 247, 0.2); color: #d8b4fe; }
  .kind-badge.udp_stun { background: rgba(236, 72, 153, 0.2); color: #f9a8d4; }
  .target-kpis {
    display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-top: 4px;
  }
  .target-kpis > div { text-align: center; }
  .target-kpis span {
    display: block;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .target-kpis b { font-size: 15px; font-variant-numeric: tabular-nums; }
  .verdict-badge {
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    text-align: center;
  }
  .verdict-badge.good { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
  .verdict-badge.warn { background: rgba(245, 158, 11, 0.15); color: #fcd34d; }
  .verdict-badge.bad { background: rgba(239, 68, 68, 0.15); color: #fca5a5; }
  .target-chart-wrap { position: relative; height: 72px; }
  .target-bursts { font-size: 12px; color: var(--muted); max-height: 110px; overflow-y: auto; }
  .target-bursts .burst {
    display: flex; justify-content: space-between;
    padding: 3px 0; border-bottom: 1px solid #334155;
  }
  .target-bursts .burst:last-child { border-bottom: none; }
</style>
</head>
<body>
<div class="container">

  <h1>Wi-Fi Performance Report</h1>
  <div class="subtitle" id="subtitle"></div>

  <div id="verdict"></div>

  <div class="kpi-grid" id="kpis"></div>

  <div class="card">
    <h2>Uptime Over Time</h2>
    <div class="card-sub">Percentage of probes that succeeded each hour. 100% = perfect. Dips = outages.</div>
    <div class="chart-container"><canvas id="uptimeChart"></canvas></div>
  </div>

  <div class="card">
    <h2>Latency Over Time</h2>
    <div class="card-sub">Median and 95th-percentile round-trip time per hour (milliseconds). Lower is better. Consumer broadband should stay under ~50 ms median.</div>
    <div class="chart-container"><canvas id="latencyChart"></canvas></div>
  </div>

  <div class="card">
    <h2>Failure Rate by Target</h2>
    <div class="card-sub">One bar per probed service. Red = &gt;1% failure, amber = 0.1&ndash;1%, green = &lt;0.1%. Tiny visible bars on green targets just mark them as measured (real value in tooltip). ICMP, TCP :443, UDP DNS, and UDP STUN are all independent &mdash; if STUN fails while ICMP passes, calls will break even though <code>ping</code> looks fine.</div>
    <div class="chart-container"><canvas id="targetChart"></canvas></div>
  </div>

  <div class="card">
    <h2>Per-Target Breakdown</h2>
    <div class="card-sub">One scorecard per probed service with its own loss-over-time chart and outage burst list. Color indicates pass/fail against Microsoft Teams and Zoom voice/video recommendations: <b>loss &lt; 1%, jitter &lt; 30 ms, median RTT &lt; 150 ms</b>. A card marked <b>Fails voice/video thresholds</b> means real Teams / Zoom calls over that transport would not be reliable on this network during the measurement window.</div>
    <div class="target-grid" id="targetGrid"></div>
  </div>

  <div class="card">
    <h2>Full-Network Outage Log</h2>
    <div class="card-sub">Periods where <b>every</b> target failed for 3 or more consecutive probe cycles (~8 s minimum). Per-service outage bursts are shown on each target card above.</div>
    <table id="outageTable">
      <thead><tr><th>When (local time)</th><th class="num">Duration</th><th class="num">Cycles failed</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>

  <div class="footer">
    Generated by pingscraper. Each cycle (~2.5 s) fires 13 parallel probes: ICMP to router + 8.8.8.8 / 1.1.1.1 + teams.microsoft.com / zoom.us / outlook.office.com; TCP :443 handshake to Teams / Zoom / Outlook; DNS-over-UDP :53 to Google &amp; Cloudflare; STUN-over-UDP to stun.l.google.com:19302 &amp; stun.cloudflare.com:3478.
  </div>
</div>

<script>
const DATA = {{ data | tojson }};
const s = DATA.summary;
const TARGETS = s.targets;
const TARGET_OUTAGES = DATA.target_outages || {};

// --------------------------------------------------------------------------
// Small formatters and classifiers. Kept as named functions so the rendering
// code below stays linear and readable.
// --------------------------------------------------------------------------

const EM_DASH = "\u2014";

function formatDuration(seconds) {
  if (seconds < 60) {
    return seconds + "s";
  }
  const minutes = Math.floor(seconds / 60);
  const leftover = Math.round(seconds % 60);
  return minutes + "m " + leftover + "s";
}

function uptimeBand(pct) {
  if (pct >= 99.9) return { label: "Excellent", cls: "good" };
  if (pct >= 99)   return { label: "Acceptable", cls: "" };
  if (pct >= 95)   return { label: "Poor", cls: "warn" };
  return { label: "Unacceptable", cls: "bad" };
}

function burstsBand(count) {
  if (count === 0) return "good";
  if (count < 10)  return "warn";
  return "bad";
}

function jitterBand(ms) {
  if (ms === EM_DASH) return "";
  const v = +ms;
  if (v < 30) return "good";
  if (v < 50) return "warn";
  return "bad";
}

function stunBand(ms) {
  if (ms === EM_DASH) return "";
  const v = +ms;
  if (v < 100) return "good";
  if (v < 300) return "warn";
  return "bad";
}

function lossColor(pct) {
  if (pct > 2.5) return "#ef4444";
  if (pct > 1)   return "#f59e0b";
  return "#10b981";
}

function callQuality(t) {
  const loss = 100 - t.uptime_pct;
  const jitter = t.jitter_ms == null ? 0 : t.jitter_ms;
  const rtt = t.p50_ms == null ? 0 : t.p50_ms;

  if (loss < 1 && jitter < 30 && rtt < 150) {
    return { label: "Call-grade (meets Teams/Zoom)", cls: "good" };
  }
  if (loss < 2.5 && jitter < 50 && rtt < 300) {
    return { label: "Usable but degraded", cls: "warn" };
  }

  const fails = [];
  if (loss >= 2.5) fails.push("loss " + loss.toFixed(2) + "%");
  if (jitter >= 50) fails.push("jitter " + jitter + "ms");
  if (rtt >= 300) fails.push("RTT " + rtt + "ms");

  let label = "Fails voice/video thresholds";
  if (fails.length) {
    label = "Fails: " + fails.join(", ");
  }
  return { label: label, cls: "bad" };
}

function hostDisplay(t) {
  const host = t.host || "";
  if (!t.port) {
    return host;
  }
  return host + ":" + t.port;
}

function safeIdFor(label) {
  return label.replace(/[^a-z0-9]+/gi, "_");
}

// --------------------------------------------------------------------------
// Overall summary numbers (computed once, reused below).
// --------------------------------------------------------------------------

const targetsArr = Object.values(TARGETS);

let overallUptime = 0;
if (targetsArr.length) {
  const sumUptime = targetsArr.reduce((a, t) => a + t.uptime_pct, 0);
  overallUptime = sumUptime / targetsArr.length;
}

const routerT = TARGETS.router_icmp || TARGETS.router;

const externalTargets = [];
Object.entries(TARGETS).forEach(([k, v]) => {
  if (!k.startsWith("router")) {
    externalTargets.push(v);
  }
});
let externalUptime = 0;
if (externalTargets.length) {
  const sumExternal = externalTargets.reduce((a, t) => a + t.uptime_pct, 0);
  externalUptime = sumExternal / externalTargets.length;
}

const callTargets = [];
Object.entries(TARGETS).forEach(([k, v]) => {
  if (/teams|zoom|outlook|stun/.test(k)) {
    callTargets.push(v);
  }
});
const callFailCount = callTargets.filter(t => callQuality(t).cls !== "good").length;

const totalTargetBursts = Object.values(TARGET_OUTAGES)
  .reduce((a, arr) => a + arr.length, 0);

const stunTargets = [];
Object.entries(TARGETS).forEach(([k, v]) => {
  if (k.includes("stun")) {
    stunTargets.push(v);
  }
});

let medianStun = EM_DASH;
const allStunHaveP50 = stunTargets.length && stunTargets.every(t => t.p50_ms != null);
if (allStunHaveP50) {
  const sumP50 = stunTargets.reduce((a, t) => a + t.p50_ms, 0);
  medianStun = (sumP50 / stunTargets.length).toFixed(0);
}

const jitterValues = [];
targetsArr.forEach(t => {
  if (t.jitter_ms != null) {
    jitterValues.push(t.jitter_ms);
  }
});
let worstJitter = EM_DASH;
if (jitterValues.length) {
  worstJitter = Math.max.apply(null, jitterValues).toFixed(1);
}

// --------------------------------------------------------------------------
// Header
// --------------------------------------------------------------------------

const startStr = new Date(s.window_start_utc).toLocaleString();
const endStr = new Date(s.window_end_utc).toLocaleString();
const targetCount = Object.keys(TARGETS).length;
document.getElementById("subtitle").textContent =
  startStr + " \u2192 " + endStr +
  " (" + s.duration_hours + " hours, " +
  s.total_pings.toLocaleString() + " probes across " + targetCount + " targets)";

// --------------------------------------------------------------------------
// Verdict banner
// --------------------------------------------------------------------------

function buildVerdictCause() {
  if (callFailCount > 0) {
    return callFailCount + " of " + callTargets.length +
      " call-related probes (Teams / Zoom / Outlook / STUN) failed Microsoft's own voice/video quality thresholds.";
  }
  if (routerT && routerT.uptime_pct > 99 && externalUptime < 99) {
    return "Router responded fine but external probes failed \u2014 the problem is upstream of the router (building uplink / ISP).";
  }
  if (routerT && routerT.uptime_pct < 99) {
    return "Probes to the router itself failed \u2014 this is a Wi-Fi link / AP coverage issue, not upstream.";
  }
  return "Service was unreliable across the full network path.";
}

function renderVerdict() {
  const degraded = overallUptime < 99 || callFailCount > 0;
  if (!degraded) {
    return '<div class="verdict good">' +
      '<div class="verdict-title">\u2713 Service was stable</div>' +
      'Overall uptime ' + overallUptime.toFixed(2) + '%; all probed services met Teams/Zoom voice/video thresholds.' +
      '</div>';
  }
  return '<div class="verdict bad">' +
    '<div class="verdict-title">\u26A0 Service degradation detected</div>' +
    'Overall uptime was ' + overallUptime.toFixed(2) + '%. ' + buildVerdictCause() +
    '</div>';
}

document.getElementById("verdict").innerHTML = renderVerdict();

// --------------------------------------------------------------------------
// KPI cards
// --------------------------------------------------------------------------

const overallBand = uptimeBand(overallUptime);

const kpiCards = [
  {
    label: "Overall Uptime",
    value: overallUptime.toFixed(2) + "%",
    sub: overallBand.label,
    cls: overallBand.cls,
  },
  {
    label: "Outage Bursts",
    value: totalTargetBursts.toLocaleString(),
    sub: DATA.outages.length + " full-network, " + totalTargetBursts +
         " per-target (\u22653 consecutive fails)",
    cls: burstsBand(totalTargetBursts),
  },
  {
    label: "STUN Median RTT",
    value: medianStun + " ms",
    sub: "WebRTC call-plane (Teams/Zoom use this protocol)",
    cls: stunBand(medianStun),
  },
  {
    label: "Worst Jitter",
    value: worstJitter + " ms",
    sub: "Teams / Zoom require < 30 ms for clean voice",
    cls: jitterBand(worstJitter),
  },
];

function renderKpi(k) {
  return '<div class="kpi ' + k.cls + '">' +
    '<div class="kpi-label">' + k.label + '</div>' +
    '<div class="kpi-value">' + k.value + '</div>' +
    '<div class="kpi-sub">' + k.sub + '</div>' +
  '</div>';
}

document.getElementById("kpis").innerHTML = kpiCards.map(renderKpi).join("");

// --------------------------------------------------------------------------
// Chart.js defaults
// --------------------------------------------------------------------------

Chart.defaults.color = "#94a3b8";
Chart.defaults.borderColor = "#334155";
Chart.defaults.font.family = "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif";

const hourLabels = DATA.hourly.map(h => h.hour);
const uptimeData = DATA.hourly.map(h => h.uptime_pct);
const medianData = DATA.hourly.map(h => h.median_rtt);
const p95Data = DATA.hourly.map(h => h.p95_rtt);

// --------------------------------------------------------------------------
// Uptime-over-time
// --------------------------------------------------------------------------

let uptimeYMin = 0;
if (uptimeData.length) {
  uptimeYMin = Math.max(0, Math.min.apply(null, uptimeData) - 5);
}

new Chart(document.getElementById("uptimeChart"), {
  type: "line",
  data: {
    labels: hourLabels,
    datasets: [{
      label: "Uptime %",
      data: uptimeData,
      borderColor: "#3b82f6",
      backgroundColor: "rgba(59, 130, 246, 0.15)",
      fill: true,
      tension: 0.2,
      pointRadius: 0,
      pointHoverRadius: 5,
      borderWidth: 2,
    }],
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: ctx => "Uptime: " + ctx.parsed.y.toFixed(2) + "%" } },
    },
    scales: {
      y: { min: uptimeYMin, max: 100, ticks: { callback: v => v + "%" } },
      x: { ticks: { maxRotation: 45, minRotation: 45, autoSkip: true, maxTicksLimit: 14 } },
    },
  },
});

// --------------------------------------------------------------------------
// Latency-over-time
// --------------------------------------------------------------------------

new Chart(document.getElementById("latencyChart"), {
  type: "line",
  data: {
    labels: hourLabels,
    datasets: [
      {
        label: "Median",
        data: medianData,
        borderColor: "#10b981",
        backgroundColor: "rgba(16, 185, 129, 0.1)",
        tension: 0.2,
        pointRadius: 0,
        pointHoverRadius: 5,
        borderWidth: 2,
      },
      {
        label: "95th percentile",
        data: p95Data,
        borderColor: "#f59e0b",
        backgroundColor: "rgba(245, 158, 11, 0.1)",
        tension: 0.2,
        pointRadius: 0,
        pointHoverRadius: 5,
        borderWidth: 2,
        borderDash: [5, 5],
      },
    ],
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position: "top", align: "end" },
      tooltip: { callbacks: { label: ctx => ctx.dataset.label + ": " + ctx.parsed.y + " ms" } },
    },
    scales: {
      y: { beginAtZero: true, ticks: { callback: v => v + " ms" } },
      x: { ticks: { maxRotation: 45, minRotation: 45, autoSkip: true, maxTicksLimit: 14 } },
    },
  },
});

// --------------------------------------------------------------------------
// Failure-rate bar chart (with min-height display so 0% targets still show)
// --------------------------------------------------------------------------

const targetLabels = Object.keys(TARGETS);
const actualFailRates = targetLabels.map(l => 100 - TARGETS[l].uptime_pct);
const displayFailRates = actualFailRates.map(r => Math.max(r, 0.05));
const targetBarColors = actualFailRates.map(lossColor);

new Chart(document.getElementById("targetChart"), {
  type: "bar",
  data: {
    labels: targetLabels,
    datasets: [{
      data: displayFailRates,
      backgroundColor: targetBarColors,
      borderRadius: 4,
    }],
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          label: ctx => "Failed: " + actualFailRates[ctx.dataIndex].toFixed(3) + "% of probes",
        },
      },
    },
    scales: {
      y: { beginAtZero: true, ticks: { callback: v => v + "%" } },
      x: { ticks: { autoSkip: false, maxRotation: 60, minRotation: 45, font: { size: 10 } } },
    },
  },
});

// --------------------------------------------------------------------------
// Per-target card grid
// --------------------------------------------------------------------------

function renderBurstRow(burst) {
  const dur = formatDuration(burst.duration_sec);
  return '<div class="burst">' +
    '<span>' + burst.start_local + '</span>' +
    '<span>' + dur + '</span>' +
  '</div>';
}

function renderBurstList(bursts) {
  if (bursts.length === 0) {
    return '<div class="target-bursts">' +
      '<em style="color:#64748b">No outage bursts</em>' +
    '</div>';
  }
  const rows = bursts.slice(0, 20).map(renderBurstRow).join("");
  let overflow = "";
  if (bursts.length > 20) {
    overflow = '<div class="burst"><em>+' + (bursts.length - 20) + ' more</em></div>';
  }
  return '<div class="target-bursts">' + rows + overflow + '</div>';
}

function renderTargetCard(label, t, bursts) {
  const q = callQuality(t);
  const safeId = safeIdFor(label);
  const kind = t.kind || "icmp";
  const kindLabel = kind.replace("_", " ");
  let p50 = EM_DASH;
  if (t.p50_ms != null) {
    p50 = t.p50_ms;
  }
  let jitter = EM_DASH;
  if (t.jitter_ms != null) {
    jitter = t.jitter_ms;
  }
  return '<div class="target-card ' + q.cls + '">' +
    '<div class="target-head">' +
      '<div class="target-name">' + label + '</div>' +
      '<span class="kind-badge ' + kind + '">' + kindLabel + '</span>' +
    '</div>' +
    '<div class="target-host">' + hostDisplay(t) + '</div>' +
    '<div class="target-kpis">' +
      '<div><span>Uptime</span><b>' + t.uptime_pct + '%</b></div>' +
      '<div><span>p50</span><b>' + p50 + ' ms</b></div>' +
      '<div><span>Jitter</span><b>' + jitter + ' ms</b></div>' +
      '<div><span>Bursts</span><b>' + bursts.length + '</b></div>' +
    '</div>' +
    '<div class="verdict-badge ' + q.cls + '">' + q.label + '</div>' +
    '<div class="target-chart-wrap"><canvas id="tc-' + safeId + '"></canvas></div>' +
    renderBurstList(bursts) +
  '</div>';
}

const grid = document.getElementById("targetGrid");
const cardHtml = [];
Object.entries(TARGETS).forEach(([label, t]) => {
  const bursts = TARGET_OUTAGES[label] || [];
  cardHtml.push(renderTargetCard(label, t, bursts));
});
grid.innerHTML = cardHtml.join("");

// --------------------------------------------------------------------------
// Mini loss-per-hour chart per target
// --------------------------------------------------------------------------

function lossPerHourFor(label) {
  const out = [];
  DATA.hourly.forEach(h => {
    const bucket = h.by_target && h.by_target[label];
    if (!bucket || !bucket.total) {
      out.push(0);
      return;
    }
    const loss = 100 - bucket.uptime_pct;
    out.push(+loss.toFixed(2));
  });
  return out;
}

Object.keys(TARGETS).forEach(label => {
  const canvas = document.getElementById("tc-" + safeIdFor(label));
  if (!canvas) {
    return;
  }
  const lossPerHour = lossPerHourFor(label);
  const yMax = Math.max(5, Math.max.apply(null, lossPerHour.length ? lossPerHour : [0]));
  new Chart(canvas, {
    type: "bar",
    data: {
      labels: hourLabels,
      datasets: [{
        data: lossPerHour,
        backgroundColor: lossPerHour.map(lossColor),
        borderRadius: 1,
        barPercentage: 1,
        categoryPercentage: 1,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => ctx.label + ": " + ctx.parsed.y + "% loss" } },
      },
      scales: {
        y: { beginAtZero: true, suggestedMax: yMax, ticks: { display: false }, grid: { display: false } },
        x: { ticks: { display: false }, grid: { display: false } },
      },
    },
  });
});

// --------------------------------------------------------------------------
// Full-network outage table
// --------------------------------------------------------------------------

function renderOutageRow(o) {
  const dur = formatDuration(o.duration_sec);
  return '<tr>' +
    '<td>' + o.start_local + '</td>' +
    '<td class="num">' + dur + '</td>' +
    '<td class="num">' + o.consecutive_cycles_failed + '</td>' +
  '</tr>';
}

const tbody = document.querySelector("#outageTable tbody");
if (DATA.outages.length === 0) {
  tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;color:#94a3b8;padding:24px;">' +
    'No full-network outages. See per-target cards above for per-service bursts.' +
  '</td></tr>';
} else {
  tbody.innerHTML = DATA.outages.map(renderOutageRow).join("");
}
</script>
</body>
</html>
